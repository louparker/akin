# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.
# The service-role key is NOT listed here: it lives only in Supabase function
# secrets and GitHub Actions secrets, never in the client environment.

# ── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── Sentry ───────────────────────────────────────────────────────────────────
# Found in: Sentry → Project → Settings → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=

# ── PostHog ──────────────────────────────────────────────────────────────────
# Found in: PostHog → Project Settings → Project API Key
EXPO_PUBLIC_POSTHOG_KEY=
