{
  "name": "akin",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e:ios": "maestro test --device 'iPhone 15' e2e/",
    "test:e2e:android": "maestro test --device emulator-5554 e2e/",
    "db:up": "supabase start",
    "db:down": "supabase stop",
    "db:reset": "supabase db reset",
    "db:test": "supabase test db",
    "db:gen-types": "supabase gen types typescript --local > src/types/database.ts",
    "db:push": "supabase db push",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@shopify/flash-list": "^2.3.1",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.10",
    "clsx": "^2.1.1",
    "expo": "55.0.18",
    "expo-clipboard": "^55.0.13",
    "expo-constants": "~55.0.15",
    "expo-font": "^55.0.7",
    "expo-haptics": "^55.0.14",
    "expo-linking": "~55.0.14",
    "expo-localization": "^55.0.14",
    "expo-router": "~55.0.13",
    "expo-secure-store": "^55.0.14",
    "expo-status-bar": "~55.0.5",
    "nativewind": "^4.2.4",
    "posthog-react-native": "^4.45.7",
    "react": "19.2.0",
    "react-error-boundary": "^4.1.2",
    "react-hook-form": "^7.76.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.19",
    "zod": "^4.4.3",
    "zustand": "5"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~55.0",
    "eslint": "8",
    "eslint-config-expo": "55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "jest": "^29",
    "jest-expo": "^55.0.17",
    "lint-staged": "^17.0.5",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "packageManager": "pnpm@8.15.9",
  "private": true,
  "pnpm": {
    "overrides": {
      "hermes-parser": "0.35.0"
    }
  }
}
